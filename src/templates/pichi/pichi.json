{
  "_manifest": {
    "type": "template",
    "name": "pichi",
    "version": "1.0.0",
    "authorized_domain": "localhost",
    "signature": "default_signature"
  },
  "theme_config": {
    "typography": {
      "heading": "Inter, sans-serif",
      "body": "Roboto, sans-serif"
    },
    "colors": {
      "accent": "#3b82f6",
      "background": "#0a0a0a",
      "text": "#f5f5f5"
    },
    "width": "1200px"
  },
  "globals": {
    "header": [
      {
        "id": "header_1",
        "tag": "header",
        "classes": ["pichi-header"],
        "children": [
          {
            "id": "header_container",
            "tag": "div",
            "classes": ["pichi-container", "pichi-header-container"],
            "children": [
              { "tag": "h3", "classes": ["pichi-logo"], "children": ["ESCMS"] },
              { "tag": "nav", "children": [
                { "tag": "a", "classes": ["pichi-nav-link"], "children": ["Home"] },
                { "tag": "a", "classes": ["pichi-nav-link"], "children": ["Blog"] }
              ] }
            ]
          }
        ]
      }
    ],
    "footer": [
      {
        "id": "footer_1",
        "tag": "footer",
        "classes": ["pichi-footer"],
        "children": [
          "Powered by ESCMS - The Zero-Bloat CMS"
        ]
      }
    ]
  },
  "views": {
    "home": [
      {
        "id": "hero_1",
        "tag": "section",
        "classes": ["pichi-hero"],
        "children": [
          { "tag": "h1", "classes": ["pichi-hero-title"], "children": ["Welcome to the Pichi Template"] },
          { "tag": "p", "classes": ["pichi-hero-subtitle"], "children": ["This is the default starting point for your new website. Edit anything directly on the canvas."] },
          { "tag": "a", "classes": ["pichi-btn"], "children": ["Get Started"] }
        ]
      }
    ]
  }
}
