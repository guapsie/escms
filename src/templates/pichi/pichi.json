{
  "_manifest": {
    "type": "template",
    "name": "pichi",
    "version": "1.0.0",
    "authorized_domain": "localhost",
    "signature": "default_signature"
  },
  "theme_config": {
    "typography": {
      "heading": "Inter, sans-serif",
      "body": "Roboto, sans-serif"
    },
    "colors": {
      "accent": "#3b82f6",
      "background": "#0a0a0a",
      "text": "#f5f5f5"
    },
    "width": "1200px",
    "google_fonts": [
      "https://fonts.googleapis.com/css2?family=Inter:wght@400;700&family=Roboto:wght@400;500&display=swap"
    ]
  },
  "globals": {
    "header": [
      {
        "id": "header_1",
        "tag": "header",
        "classes": [
          "pichi-header"
        ],
        "children": [
          {
            "id": "header_container",
            "tag": "div",
            "classes": [
              "pichi-container",
              "pichi-header-container"
            ],
            "children": [
              {
                "tag": "h3",
                "classes": [
                  "pichi-logo"
                ],
                "children": [
                  "ESCMS"
                ]
              }
            ]
          }
        ]
      }
    ],
    "footer": [
      {
        "id": "footer_1",
        "tag": "footer",
        "classes": [
          "pichi-footer"
        ],
        "children": [
          "Powered by ESCMS - The Zero-Bloat CMS"
        ]
      }
    ]
  },
  "views": {
    "home": [
      {
        "id": "hero_1",
        "tag": "section",
        "classes": [
          "pichi-hero"
        ],
        "children": [
          {
            "tag": "h1",
            "classes": [
              "pichi-hero-title"
            ],
            "children": [
              "Welcome to the Pichi Template"
            ]
          },
          {
            "tag": "p",
            "classes": [
              "pichi-hero-subtitle"
            ],
            "children": [
              "This is the default starting point for your new website. Edit anything directly on the canvas."
            ]
          },
          {
            "tag": "a",
            "classes": [
              "pichi-btn"
            ],
            "attributes": {
              "href": "/admin"
            },
            "children": [
              "Get Started"
            ]
          }
        ]
      }
    ],
    "page": [
      {
        "tag": "div",
        "classes": [
          "pichi-container"
        ],
        "styles": "max-width: var(--max-width); margin: 0 auto; padding: 40px 20px;",
        "children": [
          {
            "tag": "h1",
            "children": [
              "Standard Page"
            ]
          },
          {
            "tag": "p",
            "children": [
              "Start adding your content here."
            ]
          }
        ]
      }
    ],
    "blog": [
      {
        "tag": "div",
        "classes": [
          "pichi-container"
        ],
        "styles": "max-width: var(--max-width); margin: 0 auto; padding: 40px 20px;",
        "children": [
          {
            "tag": "h1",
            "children": [
              "Our Blog"
            ]
          },
          {
            "tag": "p",
            "children": [
              "Latest updates and articles."
            ]
          }
        ]
      }
    ],
    "404": [
      {
        "tag": "div",
        "classes": [
          "pichi-container"
        ],
        "styles": "max-width: var(--max-width); margin: 100px auto; padding: 40px 20px; text-align: center;",
        "children": [
          {
            "tag": "h1",
            "styles": "font-size: 4rem; margin-bottom: 20px;",
            "children": [
              "404"
            ]
          },
          {
            "tag": "p",
            "children": [
              "Oops! The page you're looking for doesn't exist."
            ]
          },
          {
            "tag": "a",
            "classes": [
              "pichi-btn"
            ],
            "attributes": {
              "href": "/"
            },
            "children": [
              "Go Home"
            ]
          }
        ]
      }
    ]
  }
}